# PagoPy Mobile App - Environment Configuration Template
# Copy this file to .env for local development
# These values are hardcoded in environment.ts and environment.prod.ts files

# ==============================================
# API Configuration
# ==============================================
# Backend API URL (without /api suffix)
API_URL=http://localhost:3000/api

# API timeout in milliseconds
API_TIMEOUT=30000

# Health check configuration
HEALTH_CHECK_ENDPOINT=/health
HEALTH_CHECK_TIMEOUT=5000
HEALTH_CHECK_INTERVAL=30000

# ==============================================
# SET (e-Kuatia) Electronic Invoicing
# ==============================================
# SET API URL for electronic invoicing
SET_API_URL=https://ekuatia-test.set.gov.py/api

# SET Environment: TEST or PRODUCTION
SET_ENVIRONMENT=TEST

# SET Timbrado number (required for production)
SET_TIMBRADO=

# Business RUC (required for production)
SET_RUC=

# Enable/disable electronic invoicing
SET_ENABLED=false

# ==============================================
# Capacitor Configuration
# ==============================================
CAPACITOR_APP_ID=py.pago.app
CAPACITOR_APP_NAME=PagoPy DEV

# ==============================================
# Feature Flags
# ==============================================
FEATURE_OFFLINE_MODE=true
FEATURE_ANALYTICS=false
FEATURE_DEBUG_LOGS=true
FEATURE_CRASH_REPORTING=false
FEATURE_PERFORMANCE_MONITORING=false
FEATURE_BLUETOOTH_PRINTING=true
FEATURE_BIOMETRIC_AUTH=true
FEATURE_AUTO_BACKUP=true
FEATURE_PUSH_NOTIFICATIONS=true
FEATURE_CAMERA_UPLOAD=true
FEATURE_BARCODE_SCANNER=true
FEATURE_THERMAL_PRINTER=true
FEATURE_ELECTRONIC_INVOICING=false

# ==============================================
# Sync Configuration
# ==============================================
# Auto sync interval in milliseconds (5 minutes = 300000)
SYNC_AUTO_INTERVAL=300000

# Auto sync on app startup
SYNC_ON_STARTUP=true

# Auto sync when network restored
SYNC_ON_NETWORK_RESTORE=true

# Maximum retry attempts
SYNC_MAX_RETRIES=3

# Retry delay in milliseconds
SYNC_RETRY_DELAY=1000

# Batch size for syncing
SYNC_BATCH_SIZE=5

# Cleanup old synced sales after N days
SYNC_CLEANUP_DAYS=30

# Sync only on WiFi (false = allow cellular)
SYNC_ONLY_WIFI=false

# Background sync enabled
SYNC_BACKGROUND_ENABLED=true

# ==============================================
# Storage Configuration
# ==============================================
# Encrypt sensitive data in storage
STORAGE_ENCRYPT=false

# Max cache size in bytes (50 MB = 52428800)
STORAGE_MAX_CACHE_SIZE=52428800

# Clear cache on logout
STORAGE_CLEAR_ON_LOGOUT=true

# Enable compression
STORAGE_COMPRESSION=false

# Database name
STORAGE_DATABASE_NAME=pagopy_dev_db

# ==============================================
# Logging Configuration
# ==============================================
# Log level: debug, info, warn, error
LOG_LEVEL=debug

# Enable console logging
LOG_CONSOLE=true

# Enable remote logging
LOG_REMOTE=false

# Max log size
LOG_MAX_SIZE=1000

# Log to file
LOG_TO_FILE=false

# ==============================================
# Security Configuration
# ==============================================
# Enable SSL pinning (production only)
SECURITY_SSL_PINNING=false

# Session timeout in milliseconds (1 hour = 3600000)
SECURITY_SESSION_TIMEOUT=3600000

# Require biometric for sensitive operations
SECURITY_REQUIRE_BIOMETRIC=false

# Auto lock timeout in milliseconds (0 = disabled)
SECURITY_AUTO_LOCK_TIMEOUT=0

# Max login attempts
SECURITY_MAX_LOGIN_ATTEMPTS=5

# ==============================================
# Network Configuration
# ==============================================
NETWORK_RETRY_ATTEMPTS=3
NETWORK_RETRY_DELAY=1000
NETWORK_CONNECTION_TIMEOUT=10000
NETWORK_ENABLE_OFFLINE=true

# ==============================================
# External Services
# ==============================================
# Sentry Error Tracking
SENTRY_DSN=
SENTRY_ENABLED=false
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0

# Firebase
FIREBASE_ENABLED=false
FIREBASE_API_KEY=
FIREBASE_PROJECT_ID=pagopy-dev

# Analytics
ANALYTICS_ENABLED=false
ANALYTICS_TRACKING_ID=

# ==============================================
# Default Settings
# ==============================================
DEFAULT_CURRENCY=PYG
DEFAULT_LOCALE=es-PY
DEFAULT_TIMEZONE=America/Asuncion
DEFAULT_TAX_RATE=10
DEFAULT_DATE_FORMAT=DD/MM/YYYY
DEFAULT_TIME_FORMAT=HH:mm
DEFAULT_ITEMS_PER_PAGE=20

# ==============================================
# Printer Configuration
# ==============================================
PRINTER_TYPE=thermal
PRINTER_PAPER_WIDTH=80
PRINTER_FONT_SIZE=12
PRINTER_AUTO_PRINT=false
PRINTER_COPIES=1

# ==============================================
# Notes
# ==============================================
# This file serves as documentation for available configuration options.
# Actual configuration is stored in:
# - src/environments/environment.ts (development)
# - src/environments/environment.prod.ts (production)
#
# To modify configuration:
# 1. Edit the appropriate environment file
# 2. Rebuild the app: nx build mobile
# 3. Sync with Capacitor: npx cap sync
