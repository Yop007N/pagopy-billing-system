# ============================================
# APPLICATION CONFIGURATION
# ============================================
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:4200

# ============================================
# DATABASE CONFIGURATION
# ============================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pagopy_db?schema=public"

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRES_IN=30d

# ============================================
# SET (e-Kuatia) INTEGRATION
# ============================================
SET_API_URL=https://ekuatia.set.gov.py/api
SET_API_KEY=your-set-api-key
SET_API_SECRET=your-set-api-secret
SET_ENVIRONMENT=TEST # TEST or PRODUCTION
SET_TIMBRADO=your-timbrado-number
SET_RUC=your-business-ruc

# ============================================
# SIPAP INTEGRATION (Pago móvil Paraguay)
# ============================================
SIPAP_API_URL=https://api.sipap.gov.py
SIPAP_MERCHANT_ID=your-merchant-id
SIPAP_API_KEY=your-sipap-api-key
SIPAP_SECRET_KEY=your-sipap-secret-key
SIPAP_WEBHOOK_SECRET=your-sipap-webhook-secret

# ============================================
# BANCARD INTEGRATION
# ============================================
BANCARD_API_URL=https://vpos.infonet.com.py
BANCARD_PUBLIC_KEY=your-bancard-public-key
BANCARD_PRIVATE_KEY=your-bancard-private-key
BANCARD_PROCESS_ID=your-process-id
BANCARD_ENVIRONMENT=STAGING # STAGING or PRODUCTION
BANCARD_RETURN_URL=http://localhost:4200/payment/success
BANCARD_CANCEL_URL=http://localhost:4200/payment/cancel

# ============================================
# TWILIO (SMS/WhatsApp NOTIFICATIONS)
# ============================================
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+595981234567
TWILIO_WHATSAPP_NUMBER=whatsapp:+595981234567

# ============================================
# EMAIL CONFIGURATION (SMTP)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@pagopy.com

# ============================================
# FILE STORAGE
# ============================================
STORAGE_TYPE=LOCAL # LOCAL, S3, or GCS
STORAGE_PATH=./uploads
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=pagopy-invoices

# ============================================
# REDIS (OPTIONAL - FOR CACHING)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# RATE LIMITING
# ============================================
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=debug # error, warn, info, debug, verbose
LOG_FILE_PATH=./logs

# ============================================
# WEBHOOKS
# ============================================
WEBHOOK_SECRET=your-webhook-secret-key
