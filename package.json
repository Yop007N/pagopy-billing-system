{
  "name": "pago-py",
  "version": "1.0.0",
  "description": "Sistema de Gestión de Pagos y Facturación Electrónica para Paraguay",
  "author": "PagoPy Team",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "start": "./scripts/start-dev.sh",
    "stop": "./scripts/stop-dev.sh",
    "dev": "nx run-many --target=serve --projects=web,backend --parallel",
    "dev:web": "nx serve web",
    "dev:backend": "nx serve backend",
    "dev:mobile": "nx serve mobile",
    "build": "nx run-many --target=build --all",
    "build:web": "nx build web --configuration=production",
    "build:backend": "nx build backend --configuration=production",
    "build:mobile": "nx build mobile --configuration=production",
    "test": "nx run-many --target=test --all",
    "lint": "nx run-many --target=lint --all",
    "format": "nx format:write",
    "format:check": "nx format:check",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:restart": "docker-compose restart",
    "prisma:migrate": "nx run backend:prisma-migrate",
    "prisma:generate": "nx run backend:prisma-generate",
    "prisma:studio": "nx run backend:prisma-studio",
    "prisma:seed": "nx run backend:prisma-seed",
    "setup": "pnpm install && pnpm docker:up && pnpm prisma:generate && cd apps/backend && npx prisma db push"
  },
